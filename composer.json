{
    "name": "wp-migrate/url-replace",
    "description": "WordPress URL Replace Tool - 仿照 All-in-One WP Migration 的高韌性 URL 替換工具",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "WpMigrate\\Src\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpMigrate\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    }
}
